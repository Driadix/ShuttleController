# .clang-format - Файл конфигурации для инструмента форматирования Clang
# Полный список опций: https://clang.llvm.org/docs/ClangFormatStyleOptions.html

# Базовый стиль для наследования - использует стиль Google как отправную точку
# Возможные значения: LLVM, Google, Chromium, Mozilla, WebKit, Microsoft, GNU или пользовательский файл
BasedOnStyle: LLVM

#===============================================================================
# Параметры выравнивания и переноса строк
#===============================================================================

# Управляет выравниванием аргументов функции/метода при переносе
# 'AlwaysBreak': Всегда переносить после открывающей скобки
# Другие значения: Align, DontAlign, BlockIndent
AlignAfterOpenBracket: "AlwaysBreak"

# Выравнивать последовательные определения макросов
# 'true': Выравнивать имена макросов и их значения
# 'false': Без специального выравнивания для макросов
AlignConsecutiveMacros: "true"

# Управляет переносом инициализаторов конструктора на следующую строку
# 'false': Всегда помещать каждый инициализатор на отдельную строку
# 'true': Разрешить все инициализаторы на одной строке, если они помещаются
AllowAllConstructorInitializersOnNextLine: "false"

# Управляет переносом всех параметров объявления функции на следующую строку
# 'false': Всегда помещать каждый параметр на отдельную строку, если они не помещаются на первой
# 'true': Разрешить все параметры на одной строке, если они помещаются
AllowAllParametersOfDeclarationOnNextLine: "false"

# Управляет стилем размещения фигурных скобок
# 'Allman': Размещать фигурные скобки на новых строках
# Другие значения: Attach, Linux, Mozilla, Stroustrup и т.д.
BreakBeforeBraces: Allman

# Управляет упаковкой аргументов для вызовов функций
# 'false': Не упаковывать аргументы (один аргумент на строку, если они не помещаются)
# 'true': Упаковывать как можно больше аргументов на каждой строке
BinPackArguments: "false"

# Управляет упаковкой параметров для объявлений функций
# 'false': Не упаковывать параметры (один параметр на строку, если они не помещаются)
# 'true': Упаковывать как можно больше параметров на каждой строке
BinPackParameters: "false"

# Максимальная длина строки кода
# Более высокие значения позволяют размещать больше кода в строке перед переносом
ColumnLimit: 125

#===============================================================================
# Параметры пробелов
#===============================================================================

# Управляет пробелом после ключевого слова 'template'
# 'false': Без пробела (например, template<class T>)
# 'true': Добавлять пробел (например, template <class T>)
SpaceAfterTemplateKeyword: "false"

# Управляет пробелом перед двоеточием инициализатора конструктора
# 'true': Добавлять пробел (например, Constructor() : member(0))
# 'false': Без пробела (например, Constructor(): member(0))
SpaceBeforeCtorInitializerColon: "true"

# Управляет пробелом перед двоеточием наследования
# 'true': Добавлять пробел (например, class Derived : public Base)
# 'false': Без пробела (например, class Derived: public Base)
SpaceBeforeInheritanceColon: "true"

# Управляет пробелом перед скобками
# 'ControlStatements': Добавлять пробел только перед скобками управляющих конструкций
# Другие значения: Never, Always, NonEmptyParentheses
SpaceBeforeParens: ControlStatements

# Управляет пробелом перед двоеточием в range-based for цикле
# 'true': Добавлять пробел (например, for (auto x : range))
# 'false': Без пробела (например, for (auto x: range))
SpaceBeforeRangeBasedForLoopColon: "true"

# Управляет добавлением пробела в пустых блоках
# 'true': Добавлять пробел в пустых блоках (например, if() { })
# 'false': Без пробела в пустых блоках (например, if() {})
SpaceInEmptyBlock: true

#===============================================================================
# Параметры стиля и форматирования
#===============================================================================

# Управляет форматированием списков в фигурных скобках в C++11
# 'false': Добавлять пробел после открывающей и перед закрывающей скобкой (например, { 1, 2, 3 })
# 'true': Без пробелов внутри скобок (например, {1, 2, 3})
Cpp11BracedListStyle: "false"

# Управляет отступами пространств имён
# 'All': Делать отступы для содержимого всех пространств имён
# Другие значения: None, Inner (только для вложенных пространств имён)
NamespaceIndentation: All

# Управляет используемым стандартом C++
# 'Latest': Использовать возможности последнего стандарта C++
# Другие значения: c++03, c++11, c++14, c++17, c++20
Standard: "Latest"

#===============================================================================
# Параметры сокращения кода
#===============================================================================

# Разрешить метки case на одной строке
# 'true': Разрешить "case X: statement;" на одной строке
# 'false': Всегда переносить строку после метки case
AllowShortCaseLabelsOnASingleLine: false

# Управляет размещением коротких функций на одной строке
# 'true': Разрешить короткие функции на одной строке
# 'false': Всегда разбивать тело функции на несколько строк
# Другие значения: InlineOnly, Empty, Inline, All
AllowShortFunctionsOnASingleLine: Empty

# Управляет размещением коротких условных операторов на одной строке
# 'true': Разрешить "if (cond) statement;" на одной строке
# 'false': Всегда разбивать условные операторы на несколько строк
# Другие значения: Never, WithoutElse, OnlyFirstIf, AllIfsAndElse
AllowShortIfStatementsOnASingleLine: Never

# Управляет размещением коротких циклов на одной строке
# 'true': Разрешить "while (cond) statement;" на одной строке
# 'false': Всегда разбивать циклы на несколько строк
AllowShortLoopsOnASingleLine: false

AllowShortBlocksOnASingleLine: Never

# Использовать только пробелы. Табы по-разному отображаются в VSCode, GitHub и Arduino IDE.
UseTab: Never
IndentWidth: 4
TabWidth: 4

# Выравнивание указателя по правому краю (к имени переменной).
# Предотвращает ошибки в C: `uint8_t *a, b;` (a - указатель, b - число).
PointerAlignment: Right

# Выравнивание последовательных присваиваний (удобно для битовых масок)
AlignConsecutiveAssignments: true

# Выравнивание объявлений переменных разных типов
AlignConsecutiveDeclarations: true

BraceWrapping:
  AfterFunction: true # Скобка функции с новой строки (удобно искать)
  AfterStruct: true # Скобка структуры с новой строки
  AfterEnum: true # Скобка enum с новой строки
  AfterControlStatement: false # Для if/while скобка на той же строке (экономит место по вертикали)
  BeforeElse: false # 'else' на той же строке, что и закрывающая скобка '}'

# Автоматически сортировать #include (удобно для поддержания чистоты)
SortIncludes: true
